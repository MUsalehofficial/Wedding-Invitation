# Copy to `.env` for local dev (or `.env.local` if you use that).
# Google Apps Script Web App URL (deployed as "Anyone" and writes to your sheet).
# For GitHub Pages CI: add the same value as repo secret VITE_RSVP_SCRIPT_URL
# (Settings → Secrets and variables → Actions).
VITE_RSVP_SCRIPT_URL=

# Legacy Supabase variables (optional; keep only if other parts of the app still use Supabase).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
