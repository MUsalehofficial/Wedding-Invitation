# Copy to `.env.local` for Vite — only publishable Supabase keys (safe in frontend bundle).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# === Server secrets (Supabase Dashboard → Edge Functions → Secrets) — NEVER commit ===
#
# GOOGLE_SERVICE_ACCOUNT_JSON
#   Paste the entire JSON key file from Google Cloud (single line ok). Enable "Google Sheets API"
#   for the project, create a Service Account → Keys → JSON. Share your RSVP spreadsheet
#   with the service account email (Editor).
#
# RSVP_SPREADSHEET_ID
#   From URL: docs.google.com/spreadsheets/d/<THIS_ID>/edit
#
# RSVP_SHEET_TAB_NAME (optional)
#   Worksheet/tab name — default "RSVPs". Create an empty tab with that name or let headers auto-create row 1.
